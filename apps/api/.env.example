# Runtime application connection.
# Use PgBouncer in transaction pooling mode for API traffic.
DATABASE_URL=postgresql://postgres:postgres@localhost:6432/supernova?pgbouncer=true&connection_limit=100

# Prisma schema/migration connection.
# This must connect directly to PostgreSQL, not PgBouncer.
# Required by prisma validate/generate/migrate because schema tooling reads `directUrl`.
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/supernova

REDIS_URL=redis://localhost:6379
IMPORT_STORAGE_PATH=./var/imports
IMPORT_MAX_FILE_SIZE_BYTES=104857600
API_PORT=4000
API_REQUEST_LOGGER=
WEB_ORIGIN=http://localhost:3000
JWT_SECRET=replace-with-a-long-random-local-secret
JWT_EXPIRES_IN=8h
TEMP_PASSWORD_ENCRYPTION_KEY=replace-with-a-different-long-random-local-secret
AUTH_COOKIE_NAME=supernova_session
HR_SYNC_ENABLED=false
HR_SYNC_WEB_APP_URL=
HR_SYNC_SECRET=
SEED_ADMIN_PHONE=01000000000
SEED_ADMIN_NATIONAL_ID=29901010000001
SEED_ADMIN_PASSWORD=
SEED_ADMIN_NAME=SuperNova Admin
