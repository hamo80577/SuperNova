generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  PICKER
  CHAMP
  AREA_MANAGER
  ADMIN
  SUPER_ADMIN
}

enum AccessRoleKind {
  SYSTEM
  CUSTOM
}

enum AccessRoleStatus {
  ACTIVE
  INACTIVE
}

enum AccessRoleAssignmentStatus {
  ACTIVE
  INACTIVE
}

enum AccountStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  ARCHIVED
}

enum EmploymentStatus {
  NEW_HIRE_PENDING
  ACTIVE
  RESIGNED
  ARCHIVED
}

enum ProfileStatus {
  INCOMPLETE
  PENDING_REVIEW
  COMPLETE
}

enum BlockStatus {
  NO_BLOCK
  TEMPORARY_BLOCK
  PERMANENT_BLOCK
}

enum Gender {
  MALE
  FEMALE
  UNSPECIFIED
}

enum UiTheme {
  ORANGE
  TEAL
  BLUE
  EMERALD
  VIOLET
  SLATE
}

enum AssignmentStatus {
  ACTIVE
  CLOSED
}

enum VendorStatus {
  ACTIVE
  INACTIVE
}

enum ChainStatus {
  ACTIVE
  INACTIVE
}

enum RequestType {
  NEW_HIRE
  RESIGNATION
  TRANSFER
}

enum RequestStatus {
  DRAFT
  PENDING_AREA_MANAGER
  PENDING_DESTINATION_AREA_MANAGER
  PENDING_ADMIN
  APPROVED
  REJECTED
  CANCELLED
  COMPLETED
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  SKIPPED
}

enum ApprovalStep {
  AREA_MANAGER_APPROVAL
  SOURCE_AREA_MANAGER_APPROVAL
  DESTINATION_AREA_MANAGER_APPROVAL
  ADMIN_FINAL_APPROVAL
}

enum HrSyncWorkflowType {
  PICKER_NEW_HIRE
  PICKER_REHIRE
  PICKER_RESIGNATION
}

enum HrSyncTargetSheet {
  NEW_HIRE
  RESIGN
}

enum HrSyncStatus {
  NOT_SENT
  SENT
  FAILED
  SKIPPED
}

enum AttendanceImportBatchStatus {
  UPLOADED
  VALIDATED
  CONFIRMED
  ACTIVE
  REPLACED
  FAILED
  LOCKED
}

enum AttendanceImportMode {
  MTD
  HISTORICAL_MONTH
}

enum AttendanceCalculatedStatus {
  ON_TIME
  LATE
  ABSENT
  OFF_DAY
  ANNUAL_LEAVE
  MEDICAL_LEAVE
  OTHER_LEAVE
  EXCLUDED_NON_EGYPT
  UNMATCHED_IDENTIFIER
  EXCLUDED_NOT_PICKER
  INVALID_OR_MISSING_ATTENDANCE_DATA
}

enum AttendanceLateBucket {
  NONE
  LATE_1
  LATE_2
  LATE_3
}

enum AttendanceLeaveType {
  ANNUAL_LEAVE
  MEDICAL_LEAVE
  OTHER_LEAVE
}

enum AttendanceMatchStatus {
  MATCHED_PICKER
  UNMATCHED_IDENTIFIER
  EXCLUDED_NOT_PICKER
  EXCLUDED_NON_EGYPT
}

enum AttendanceLocationMappingStatus {
  NOT_CHECKED
  MAPPED_VENDOR_CODE
  MAPPED_VENDOR_EXTERNAL_ID
  UNMAPPED
  MISSING_CODE
}

enum AttendanceAssignmentMismatchStatus {
  NOT_CHECKED
  MATCHES_ACTIVE_ASSIGNMENT
  DIFFERS_FROM_ACTIVE_ASSIGNMENT
  NO_ACTIVE_ASSIGNMENT
}

enum AttendanceIssueSeverity {
  ERROR
  WARNING
}

enum AttendanceIssueResolutionStatus {
  OPEN
  IGNORED
  RESOLVED
}

enum AttendanceIssueCode {
  MTD_COVERAGE_START_NOT_MONTH_START
  MTD_COVERAGE_END_NOT_YESTERDAY
  MTD_INCLUDES_UPLOAD_DAY
  MTD_INCLUDES_FUTURE_DATE
  MISSING_IDENTIFIER
  UNMATCHED_IDENTIFIER
  MATCHED_USER_NOT_PICKER
  NON_EGYPT_ROW
  INVALID_SHIFT_DATE
  INVALID_TIME
  MISSING_CHECKIN
  UNKNOWN_STATUS
  DUPLICATE_PICKER_DATE
  MULTIPLE_MONTHS_IN_FILE
  INVALID_REQUIRED_COLUMN
  INVALID_WORK_DURATION
  INVALID_SHIFT_DURATION
  INVALID_BREAK_DURATION
  UNMAPPED_ATTENDANCE_LOCATION
  LOCATION_SHIFT_LOCATION_DIFFERENCE
  ACTIVE_ASSIGNMENT_MISMATCH
  MISSING_ATTENDANCE_LOCATION_CODE
  INVALID_ATTENDANCE_IMPORT_MODE
  HISTORICAL_PERIOD_MONTH_REQUIRED
  INVALID_HISTORICAL_PERIOD_MONTH
  HISTORICAL_PERIOD_MONTH_NOT_CLOSED
  SHIFT_DATE_OUTSIDE_SELECTED_PERIOD_MONTH
}

enum OrdersKpiImportBatchStatus {
  VALIDATED
  NEEDS_REVIEW
  CONFIRMED
  REJECTED
  FAILED
}

enum OrdersKpiVendorMatchStatus {
  MATCHED_VENDOR
  UNMAPPED_VENDOR_ID
}

enum OrdersKpiPickerMatchStatus {
  MATCHED_PICKER
  UNMATCHED_SHOPPER_ID
  UNKNOWN_PICKER
  MATCHED_USER_NOT_PICKER
}

enum OrdersKpiIssueSeverity {
  WARNING
  ERROR
}

enum OrdersKpiIssueCode {
  MISSING_REQUIRED_COLUMNS
  MISSING_DATE
  INVALID_DATE
  MISSING_VENDOR_ID
  AMBIGUOUS_VENDOR_ID
  INVALID_NUMERIC_METRIC
  NEGATIVE_METRIC
  UNSAFE_DUPLICATE_CONFLICT
  UNMAPPED_VENDOR_ID
  MISSING_SHOPPER_ID
  NO_DATA_SHOPPER_ID
  UNMATCHED_SHOPPER_ID
  MATCHED_USER_NOT_PICKER
  PREPARATION_TIME_MISSING
  SUSPICIOUS_METRIC_VALUE
}

model User {
  id                          String                           @id @default(uuid())
  ibsId                       String?                          @unique
  shopperId                   String?                          @unique
  role                        UserRole
  nameEn                      String
  nameAr                      String?
  phoneNumber                 String                           @unique
  nationalId                  String?                          @unique
  address                     String?
  dateOfBirth                 DateTime?
  gender                      Gender                           @default(UNSPECIFIED)
  uiTheme                     UiTheme                          @default(ORANGE)
  joiningDate                 DateTime?
  employmentStatus            EmploymentStatus                 @default(NEW_HIRE_PENDING)
  resignationDate             DateTime?
  accountStatus               AccountStatus                    @default(INACTIVE)
  profileStatus               ProfileStatus                    @default(INCOMPLETE)
  blockStatus                 BlockStatus                      @default(NO_BLOCK)
  blockedUntil                DateTime?
  blockReason                 String?
  passwordHash                String
  mustChangePassword          Boolean                          @default(false)
  temporaryPasswordExpiresAt  DateTime?
  temporaryPasswordCiphertext String?
  temporaryPasswordCreatedAt  DateTime?
  lastLoginAt                 DateTime?
  createdAt                   DateTime                         @default(now())
  updatedAt                   DateTime                         @updatedAt
  pickerBranchAssignments     PickerBranchAssignment[]         @relation("PickerAssignments")
  vendorChampAssignments      VendorChampAssignment[]          @relation("VendorChampAssignments")
  chainAreaManagerAssignments ChainAreaManagerAssignment[]     @relation("ChainAreaManagerAssignments")
  createdRequests             Request[]                        @relation("RequestCreatedBy")
  targetedRequests            Request[]                        @relation("RequestTargetUser")
  approvals                   RequestApproval[]                @relation("RequestApprover")
  notifications               Notification[]
  auditLogsAsActor            AuditLog[]                       @relation("AuditActor")
  accessRoleAssignments       UserAccessRoleAssignment[]       @relation("UserAccessRoleAssignments")
  uploadedAttendanceBatches   AttendanceImportBatch[]          @relation("AttendanceImportUploadedBy")
  confirmedAttendanceBatches  AttendanceImportBatch[]          @relation("AttendanceImportConfirmedBy")
  attendanceDailyRecords      AttendanceDailyRecord[]          @relation("AttendanceDailyRecordUser")
  attendanceMonthlySummaries  AttendancePickerMonthlySummary[] @relation("AttendanceMonthlySummaryUser")
  uploadedOrdersKpiBatches    OrdersKpiImportBatch[]           @relation("OrdersKpiImportUploadedBy")
  confirmedOrdersKpiBatches   OrdersKpiImportBatch[]           @relation("OrdersKpiImportConfirmedBy")
  rejectedOrdersKpiBatches    OrdersKpiImportBatch[]           @relation("OrdersKpiImportRejectedBy")
  ordersKpiStagingMatchedRows OrdersKpiImportStagingRow[]      @relation("OrdersKpiStagingMatchedUser")
  ordersKpiDailyMatchedRows   OrdersKpiDailyRecord[]           @relation("OrdersKpiDailyMatchedUser")

  @@index([role])
  @@index([role, accountStatus])
  @@index([role, employmentStatus])
  @@index([role, profileStatus])
  @@index([accountStatus])
  @@index([employmentStatus])
}

model AccessRole {
  id              String                     @id @default(uuid())
  key             String                     @unique
  name            String
  description     String?
  kind            AccessRoleKind
  systemRole      UserRole?                  @unique
  status          AccessRoleStatus           @default(ACTIVE)
  isSystem        Boolean                    @default(false)
  permissions     AccessRolePermission[]     @relation("AccessRolePermissions")
  userAssignments UserAccessRoleAssignment[] @relation("AccessRoleAssignments")
  createdAt       DateTime                   @default(now())
  updatedAt       DateTime                   @updatedAt

  @@index([kind, status])
  @@index([status])
}

model AccessRolePermission {
  id            String     @id @default(uuid())
  accessRoleId  String
  permissionKey String
  accessRole    AccessRole @relation("AccessRolePermissions", fields: [accessRoleId], references: [id], onDelete: Cascade)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@unique([accessRoleId, permissionKey])
  @@index([permissionKey])
}

model UserAccessRoleAssignment {
  id           String                     @id @default(uuid())
  userId       String
  accessRoleId String
  status       AccessRoleAssignmentStatus @default(ACTIVE)
  startsAt     DateTime                   @default(now())
  endsAt       DateTime?
  createdAt    DateTime                   @default(now())
  updatedAt    DateTime                   @updatedAt
  user         User                       @relation("UserAccessRoleAssignments", fields: [userId], references: [id], onDelete: Cascade)
  accessRole   AccessRole                 @relation("AccessRoleAssignments", fields: [accessRoleId], references: [id], onDelete: Restrict)

  @@index([userId, status])
  @@index([accessRoleId, status])
  @@index([userId, accessRoleId, status])
}

model Chain {
  id                     String                       @id @default(uuid())
  chainName              String
  chainCode              String                       @unique
  status                 ChainStatus                  @default(ACTIVE)
  createdAt              DateTime                     @default(now())
  updatedAt              DateTime                     @updatedAt
  vendors                Vendor[]
  areaManagerAssignments ChainAreaManagerAssignment[]
  sourceRequests         Request[]                    @relation("RequestSourceChain")
  destinationRequests    Request[]                    @relation("RequestDestinationChain")
  ordersKpiStagingRows   OrdersKpiImportStagingRow[]  @relation("OrdersKpiStagingMatchedChain")
  ordersKpiDailyRecords  OrdersKpiDailyRecord[]       @relation("OrdersKpiDailyMatchedChain")
}

model Vendor {
  id                    String                      @id @default(uuid())
  vendorName            String
  vendorCode            String                      @unique
  vendorExternalId      String?                     @unique
  status                VendorStatus                @default(ACTIVE)
  chainId               String
  address               String?
  area                  String?
  city                  String?
  createdAt             DateTime                    @default(now())
  updatedAt             DateTime                    @updatedAt
  chain                 Chain                       @relation(fields: [chainId], references: [id], onDelete: Restrict)
  pickerAssignments     PickerBranchAssignment[]
  champAssignments      VendorChampAssignment[]
  sourceRequests        Request[]                   @relation("RequestSourceVendor")
  destinationRequests   Request[]                   @relation("RequestDestinationVendor")
  ordersKpiStagingRows  OrdersKpiImportStagingRow[] @relation("OrdersKpiStagingMatchedVendor")
  ordersKpiDailyRecords OrdersKpiDailyRecord[]      @relation("OrdersKpiDailyMatchedVendor")

  @@index([chainId])
}

model PickerBranchAssignment {
  id                 String           @id @default(uuid())
  pickerId           String
  vendorId           String
  status             AssignmentStatus @default(ACTIVE)
  startDate          DateTime         @default(now())
  endDate            DateTime?
  createdByRequestId String?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  picker             User             @relation("PickerAssignments", fields: [pickerId], references: [id], onDelete: Restrict)
  vendor             Vendor           @relation(fields: [vendorId], references: [id], onDelete: Restrict)
  createdByRequest   Request?         @relation("RequestCreatedAssignments", fields: [createdByRequestId], references: [id], onDelete: SetNull)

  @@index([pickerId, status])
  @@index([vendorId, status])
  @@index([createdByRequestId])
}

model VendorChampAssignment {
  id        String           @id @default(uuid())
  vendorId  String
  champId   String
  status    AssignmentStatus @default(ACTIVE)
  startDate DateTime         @default(now())
  endDate   DateTime?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  vendor    Vendor           @relation(fields: [vendorId], references: [id], onDelete: Restrict)
  champ     User             @relation("VendorChampAssignments", fields: [champId], references: [id], onDelete: Restrict)

  @@index([vendorId, status])
  @@index([champId, status])
}

model ChainAreaManagerAssignment {
  id            String           @id @default(uuid())
  chainId       String
  areaManagerId String
  status        AssignmentStatus @default(ACTIVE)
  startDate     DateTime         @default(now())
  endDate       DateTime?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  chain         Chain            @relation(fields: [chainId], references: [id], onDelete: Restrict)
  areaManager   User             @relation("ChainAreaManagerAssignments", fields: [areaManagerId], references: [id], onDelete: Restrict)

  @@index([chainId, status])
  @@index([areaManagerId, status])
}

model Request {
  id                  String                   @id @default(uuid())
  type                RequestType
  status              RequestStatus            @default(DRAFT)
  createdById         String
  targetUserId        String?
  sourceChainId       String?
  sourceVendorId      String?
  destinationChainId  String?
  destinationVendorId String?
  payload             Json?
  currentStep         ApprovalStep?
  completedAt         DateTime?
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt
  createdBy           User                     @relation("RequestCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  targetUser          User?                    @relation("RequestTargetUser", fields: [targetUserId], references: [id], onDelete: SetNull)
  sourceChain         Chain?                   @relation("RequestSourceChain", fields: [sourceChainId], references: [id], onDelete: SetNull)
  sourceVendor        Vendor?                  @relation("RequestSourceVendor", fields: [sourceVendorId], references: [id], onDelete: SetNull)
  destinationChain    Chain?                   @relation("RequestDestinationChain", fields: [destinationChainId], references: [id], onDelete: SetNull)
  destinationVendor   Vendor?                  @relation("RequestDestinationVendor", fields: [destinationVendorId], references: [id], onDelete: SetNull)
  approvals           RequestApproval[]
  createdAssignments  PickerBranchAssignment[] @relation("RequestCreatedAssignments")
  hrSyncLogs          HrSyncLog[]

  @@index([status])
  @@index([status, currentStep])
  @@index([type])
  @@index([type, status])
  @@index([createdById])
  @@index([targetUserId])
  @@index([sourceChainId, status])
  @@index([sourceVendorId])
  @@index([destinationChainId, status])
  @@index([destinationVendorId])
  @@index([createdAt])
}

model RequestApproval {
  id           String         @id @default(uuid())
  requestId    String
  step         ApprovalStep
  approverRole UserRole
  approverId   String?
  status       ApprovalStatus @default(PENDING)
  decisionAt   DateTime?
  notes        String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  request      Request        @relation(fields: [requestId], references: [id], onDelete: Cascade)
  approver     User?          @relation("RequestApprover", fields: [approverId], references: [id], onDelete: SetNull)

  @@index([approverId, status])
  @@index([approverId, status, step])
  @@index([status, step])
  @@index([requestId, step])
  @@index([requestId, status])
}

model HrSyncLog {
  id               String             @id @default(uuid())
  requestId        String
  workflowType     HrSyncWorkflowType
  targetSheet      HrSyncTargetSheet
  status           HrSyncStatus       @default(NOT_SENT)
  payloadSnapshot  Json
  responseSnapshot Json?
  errorMessage     String?
  sentAt           DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  request          Request            @relation(fields: [requestId], references: [id], onDelete: Restrict)

  @@index([requestId])
  @@index([status])
  @@index([workflowType])
  @@index([createdAt])
}

model Notification {
  id        String    @id @default(uuid())
  userId    String
  type      String
  title     String
  body      String
  payload   Json?
  readAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
  @@index([userId, createdAt])
}

model AuditLog {
  id          String   @id @default(uuid())
  actorUserId String?
  action      String
  entityType  String
  entityId    String
  oldValue    Json?
  newValue    Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())
  actor       User?    @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([actorUserId, createdAt])
  @@index([entityType, entityId])
  @@index([action, createdAt])
  @@index([entityType, action, createdAt])
  @@index([createdAt])
}

model AttendanceImportBatch {
  id                      String                           @id @default(uuid())
  periodMonth             String
  fileName                String
  fileHash                String
  importMode              AttendanceImportMode             @default(MTD)
  uploadedByUserId        String
  uploadedAt              DateTime                         @default(now())
  status                  AttendanceImportBatchStatus      @default(UPLOADED)
  rowCount                Int                              @default(0)
  egyptRows               Int                              @default(0)
  matchedPickerRows       Int                              @default(0)
  unmatchedRows           Int                              @default(0)
  excludedNonPickerRows   Int                              @default(0)
  excludedNonEgyptRows    Int                              @default(0)
  errorRows               Int                              @default(0)
  warningRows             Int                              @default(0)
  coverageStartDate       DateTime?
  coverageEndDate         DateTime?
  expectedCoverageEndDate DateTime?
  replaceOfBatchId        String?
  confirmedByUserId       String?
  confirmedAt             DateTime?
  notes                   String?
  createdAt               DateTime                         @default(now())
  updatedAt               DateTime                         @updatedAt
  uploadedBy              User                             @relation("AttendanceImportUploadedBy", fields: [uploadedByUserId], references: [id], onDelete: Restrict)
  confirmedBy             User?                            @relation("AttendanceImportConfirmedBy", fields: [confirmedByUserId], references: [id], onDelete: SetNull)
  replaceOfBatch          AttendanceImportBatch?           @relation("AttendanceBatchReplacement", fields: [replaceOfBatchId], references: [id], onDelete: SetNull)
  replacedByBatches       AttendanceImportBatch[]          @relation("AttendanceBatchReplacement")
  dailyRecords            AttendanceDailyRecord[]
  monthlySummaries        AttendancePickerMonthlySummary[]
  issues                  AttendanceImportIssue[]

  @@index([periodMonth, status])
  @@index([importMode, periodMonth, status])
  @@index([uploadedAt])
  @@index([uploadedByUserId])
  @@index([confirmedByUserId])
  @@index([replaceOfBatchId])
  @@index([fileHash])
}

model AttendanceDailyRecord {
  id                      String                     @id @default(uuid())
  importBatchId           String
  periodMonth             String
  shiftDate               DateTime
  shopperId               String
  userId                  String
  pickerNameSnapshot      String
  sourceName              String?
  sourceDesignation       String?
  division                String
  sourceSubDivision       String?
  sourceLocation          String?
  sourceLocationCode      String?
  reportedVendorId        String?
  reportedChainId         String?
  reportedLocationCode    String?
  reportedLocationName    String?
  reportedLocationRaw     String?
  shiftLocationCode       String?
  shiftLocationName       String?
  shiftLocationRaw        String?
  locationMappingStatus   AttendanceLocationMappingStatus   @default(NOT_CHECKED)
  assignmentMismatchStatus AttendanceAssignmentMismatchStatus @default(NOT_CHECKED)
  shiftName               String
  scheduledStartTime      String?
  scheduledEndTime        String?
  scheduledStartAt        DateTime?
  scheduledEndAt          DateTime?
  scheduledShiftHours     Decimal?                   @db.Decimal(6, 2)
  breakDurationMins       Int?
  actualCheckinTime       DateTime?
  actualCheckoutTime      DateTime?
  actualWorkDurationHours Decimal?                   @db.Decimal(6, 2)
  sourceStatus            String?
  calculatedStatus        AttendanceCalculatedStatus
  rawLateMins             Int?
  graceMins               Int?
  chargeableLateMins      Int?
  lateBucket              AttendanceLateBucket?
  isLate                  Boolean                    @default(false)
  isOnTime                Boolean                    @default(false)
  isAbsent                Boolean                    @default(false)
  isOffDay                Boolean                    @default(false)
  isOnLeave               Boolean                    @default(false)
  leaveType               AttendanceLeaveType?
  isAnnualLeave           Boolean                    @default(false)
  isMedicalLeave          Boolean                    @default(false)
  isWorkingDay            Boolean                    @default(false)
  isUnder8Hours           Boolean                    @default(false)
  isOver15Hours           Boolean                    @default(false)
  matchStatus             AttendanceMatchStatus      @default(MATCHED_PICKER)
  rawRowNumber            Int
  rowHash                 String
  issuesCount             Int                        @default(0)
  createdAt               DateTime                   @default(now())
  updatedAt               DateTime                   @updatedAt
  importBatch             AttendanceImportBatch      @relation(fields: [importBatchId], references: [id], onDelete: Restrict)
  user                    User                       @relation("AttendanceDailyRecordUser", fields: [userId], references: [id], onDelete: Restrict)

  @@unique([importBatchId, userId, shiftDate])
  @@index([periodMonth, shiftDate])
  @@index([periodMonth, userId])
  @@index([shopperId])
  @@index([importBatchId])
  @@index([userId])
  @@index([reportedVendorId])
  @@index([reportedChainId])
  @@index([periodMonth, reportedVendorId])
  @@index([periodMonth, reportedChainId])
  @@index([locationMappingStatus])
  @@index([assignmentMismatchStatus])
}

model AttendancePickerMonthlySummary {
  id                      String                @id @default(uuid())
  periodMonth             String
  sourceBatchId           String
  shopperId               String
  userId                  String
  pickerNameSnapshot      String
  totalScheduledRows      Int                   @default(0)
  totalWorkingDays        Int                   @default(0)
  onTimeDays              Int                   @default(0)
  lateDays                Int                   @default(0)
  totalRawLateMins        Int                   @default(0)
  totalChargeableLateMins Int                   @default(0)
  late1Count              Int                   @default(0)
  late2Count              Int                   @default(0)
  late3Count              Int                   @default(0)
  absentCount             Int                   @default(0)
  leaveCount              Int                   @default(0)
  annualLeaveCount        Int                   @default(0)
  medicalLeaveCount       Int                   @default(0)
  otherLeaveCount         Int                   @default(0)
  offDayCount             Int                   @default(0)
  under8HoursCount        Int                   @default(0)
  over15HoursCount        Int                   @default(0)
  firstShiftDate          DateTime?
  lastShiftDate           DateTime?
  lastCalculatedAt        DateTime              @default(now())
  createdAt               DateTime              @default(now())
  updatedAt               DateTime              @updatedAt
  sourceBatch             AttendanceImportBatch @relation(fields: [sourceBatchId], references: [id], onDelete: Restrict)
  user                    User                  @relation("AttendanceMonthlySummaryUser", fields: [userId], references: [id], onDelete: Restrict)

  @@unique([sourceBatchId, userId])
  @@index([periodMonth, userId])
  @@index([sourceBatchId])
  @@index([shopperId])
  @@index([userId])
}

model AttendanceImportIssue {
  id               String                          @id @default(uuid())
  batchId          String
  rowNumber        Int?
  shopperId        String?
  severity         AttendanceIssueSeverity
  issueCode        AttendanceIssueCode
  fieldName        String?
  message          String
  resolutionStatus AttendanceIssueResolutionStatus @default(OPEN)
  createdAt        DateTime                        @default(now())
  updatedAt        DateTime                        @updatedAt
  batch            AttendanceImportBatch           @relation(fields: [batchId], references: [id], onDelete: Restrict)

  @@index([batchId])
  @@index([issueCode])
  @@index([severity])
  @@index([resolutionStatus])
}

model OrdersKpiImportBatch {
  id                String                      @id @default(uuid())
  fileName          String
  fileHash          String
  uploadedByUserId  String
  uploadedAt        DateTime                    @default(now())
  status            OrdersKpiImportBatchStatus
  rowCount          Int                         @default(0)
  confirmableRows   Int                         @default(0)
  skippedRows       Int                         @default(0)
  errorRows         Int                         @default(0)
  warningRows       Int                         @default(0)
  coveredDates      Json
  coveredDateFrom   DateTime?
  coveredDateTo     DateTime?
  confirmedByUserId String?
  confirmedAt       DateTime?
  rejectedByUserId  String?
  rejectedAt        DateTime?
  rejectionReason   String?
  createdAt         DateTime                    @default(now())
  updatedAt         DateTime                    @updatedAt
  uploadedBy        User                        @relation("OrdersKpiImportUploadedBy", fields: [uploadedByUserId], references: [id], onDelete: Restrict)
  confirmedBy       User?                       @relation("OrdersKpiImportConfirmedBy", fields: [confirmedByUserId], references: [id], onDelete: SetNull)
  rejectedBy        User?                       @relation("OrdersKpiImportRejectedBy", fields: [rejectedByUserId], references: [id], onDelete: SetNull)
  stagingRows       OrdersKpiImportStagingRow[]
  records           OrdersKpiDailyRecord[]
  issues            OrdersKpiImportIssue[]

  @@index([status])
  @@index([uploadedAt])
  @@index([coveredDateFrom, coveredDateTo])
  @@index([uploadedByUserId])
  @@index([confirmedByUserId])
  @@index([fileHash])
}

model OrdersKpiImportStagingRow {
  id                 String                     @id @default(uuid())
  sourceBatchId      String
  rawRowNumber       Int
  rowHash            String
  kpiDate            DateTime
  sourceVendorId     String
  matchedVendorId    String?
  matchedChainId     String?
  vendorNameSnapshot String?
  chainNameSnapshot  String?
  vendorMatchStatus  OrdersKpiVendorMatchStatus
  sourceShopperId    String?
  sourcePickerKey    String
  userId             String?
  pickerNameSnapshot String?
  pickerMatchStatus  OrdersKpiPickerMatchStatus
  totalOrders        Int
  successfulOrders   Int
  qcFailedOrders     Int
  vendorFailedOrders Int
  unhealthyOrders    Int
  orderNotOnTime     Int
  partialRefund      Int
  vendorDelay        Int
  preparationTime    Decimal?                   @db.Decimal(10, 4)
  outOfStock         Int
  firNotOnTime       Int
  priceModified      Int
  issuesCount        Int                        @default(0)
  createdAt          DateTime                   @default(now())
  updatedAt          DateTime                   @updatedAt
  sourceBatch        OrdersKpiImportBatch       @relation(fields: [sourceBatchId], references: [id], onDelete: Restrict)
  matchedVendor      Vendor?                    @relation("OrdersKpiStagingMatchedVendor", fields: [matchedVendorId], references: [id], onDelete: SetNull)
  matchedChain       Chain?                     @relation("OrdersKpiStagingMatchedChain", fields: [matchedChainId], references: [id], onDelete: SetNull)
  user               User?                      @relation("OrdersKpiStagingMatchedUser", fields: [userId], references: [id], onDelete: SetNull)

  @@unique([sourceBatchId, rawRowNumber])
  @@index([sourceBatchId])
  @@index([kpiDate])
  @@index([sourceVendorId])
  @@index([matchedVendorId])
  @@index([matchedChainId])
  @@index([sourceShopperId])
  @@index([sourcePickerKey])
  @@index([userId])
  @@index([kpiDate, sourceVendorId])
  @@index([kpiDate, matchedVendorId])
  @@index([kpiDate, matchedChainId])
}

