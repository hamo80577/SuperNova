{
  "name": "supernova",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@10.9.3",
  "workspaces": [
    "apps/web",
    "apps/api",
    "packages/shared"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace @supernova/api\" \"npm run dev:worker --workspace @supernova/api\" \"npm run dev --workspace @supernova/web\"",
    "dev:worker": "npm run dev:worker --workspace @supernova/api",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "prisma:generate": "prisma generate --schema prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema prisma/schema.prisma",
    "prisma:studio": "prisma studio --schema prisma/schema.prisma",
    "prisma:validate": "prisma validate --schema prisma/schema.prisma",
    "db:seed": "prisma db seed --schema prisma/schema.prisma",
    "db:seed:demo-workforce": "tsx prisma/seed-demo-workforce.ts",
    "db:import:pickers": "tsx prisma/import-real-pickers.ts",
    "cleanup:open-requests": "tsx apps/api/scripts/clear-open-requests.ts"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "dotenv": "^16.4.7",
    "prisma": "^6.7.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3"
  }
}
