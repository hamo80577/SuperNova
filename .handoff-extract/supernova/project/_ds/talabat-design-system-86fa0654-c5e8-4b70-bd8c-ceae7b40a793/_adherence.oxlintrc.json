{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/accent-bar/**",
              "components/button/**",
              "components/highlight/**",
              "components/logo/**",
              "components/numbered-item/**",
              "components/patch/**",
              "components/sticker/**",
              "components/two-tone-title/**",
              "ui_kits/presentation/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Poppins|DM Sans|Open Sans))/i]",
        "message": "Font not provided by the design system. Available: Poppins, DM Sans, Open Sans."
      },
      {
        "selector": "JSXOpeningElement[name.name='AccentBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:color|width|height|radius|style|key|ref|className|style|children)$/]",
        "message": "<AccentBar> doesn't accept that prop. Declared props: color, width, height, radius, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|pill|children|style|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, pill, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|dark|lime|outline)$/]",
        "message": "<Button> variant must be one of 'primary' | 'dark' | 'lime' | 'outline'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Highlight'] > JSXAttribute > JSXIdentifier[name!=/^(?:on|color|children|style|key|ref|className|style|children)$/]",
        "message": "<Highlight> doesn't accept that prop. Declared props: on, color, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Highlight'] > JSXAttribute[name.name='on'] > Literal[value!=/^(?:light|dark)$/]",
        "message": "<Highlight> on must be one of 'light' | 'dark'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Logo'] > JSXAttribute > JSXIdentifier[name!=/^(?:src|width|tilt|alt|style|key|ref|className|style|children)$/]",
        "message": "<Logo> doesn't accept that prop. Declared props: src, width, tilt, alt, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='NumberedItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:number|title|children|numberColor|titleColor|bodyColor|numberSize|style|key|ref|className|style|children)$/]",
        "message": "<NumberedItem> doesn't accept that prop. Declared props: number, title, children, numberColor, titleColor, bodyColor, numberSize, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Patch'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|shape|size|color|textColor|children|style|key|ref|className|style|children)$/]",
        "message": "<Patch> doesn't accept that prop. Declared props: variant, shape, size, color, textColor, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Patch'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:orange|burgundy|cream|lime)$/]",
        "message": "<Patch> variant must be one of 'orange' | 'burgundy' | 'cream' | 'lime'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Patch'] > JSXAttribute[name.name='shape'] > Literal[value!=/^(?:a|b|c)$/]",
        "message": "<Patch> shape must be one of 'a' | 'b' | 'c'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Sticker'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|shape|tail|children|style|key|ref|className|style|children)$/]",
        "message": "<Sticker> doesn't accept that prop. Declared props: variant, shape, tail, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Sticker'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:lime|orange|cream)$/]",
        "message": "<Sticker> variant must be one of 'lime' | 'orange' | 'cream'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Sticker'] > JSXAttribute[name.name='shape'] > Literal[value!=/^(?:a|b)$/]",
        "message": "<Sticker> shape must be one of 'a' | 'b'."
      },
      {
        "selector": "JSXOpeningElement[name.name='TwoToneLine'] > JSXAttribute > JSXIdentifier[name!=/^(?:text|color|key|ref|className|style|children)$/]",
        "message": "<TwoToneLine> doesn't accept that prop. Declared props: text, color."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
